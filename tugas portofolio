<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GIANNA | NEURAL INTERFACE FULL</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;700&family=Syncopate:wght@700&display=swap" rel="stylesheet">

    <style>
        :root {
            --c1: rgb(240, 216, 161); /* Cream */
            --c2: rgb(164, 114, 81);  /* Brown */
            --c3: rgb(221, 158, 89);  /* Orange-Brown */
            --c4: rgb(220, 240, 195); /* Soft Green */
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--c1);
            color: var(--c2);
            overflow-x: hidden;
        }

        /* 1. DYNAMIC MESH GRADIENT BACKGROUND */
        .bg-layer {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(125deg, var(--c1), var(--c4), var(--c3), var(--c1));
            background-size: 400% 400%;
            z-index: -2;
            animation: moveGradient 12s ease infinite;
        }

        @keyframes moveGradient {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* 2. HUD NAVIGATION (GLASS) */
        nav {
            position: fixed;
            top: 20px; left: 5%; right: 5%;
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px 40px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(25px);
            border-radius: 100px;
            border: 1px solid rgba(255, 255, 255, 0.4);
            z-index: 1000;
            box-shadow: 0 10px 30px rgba(164, 114, 81, 0.1);
        }

        nav h2 { font-family: 'Syncopate', sans-serif; font-size: 1rem; letter-spacing: 4px; }
        .nav-links a {
            text-decoration: none; color: var(--c2); margin-left: 20px;
            font-weight: 700; font-size: 0.75rem; text-transform: uppercase;
            letter-spacing: 1px; transition: 0.3s;
        }
        .nav-links a:hover { color: var(--c3); transform: translateY(-2px); }

        /* 3. HOME SECTION - ASYMMETRIC CORE */
        section { min-height: 100vh; padding: 120px 10% 60px; position: relative; }

        .hero-grid {
            display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 40px;
        }

        .hero-text h1 {
            font-family: 'Syncopate', sans-serif; font-size: clamp(2.5rem, 7vw, 5.5rem);
            line-height: 0.85; margin-bottom: 25px;
        }

        .hero-image-frame {
            width: 100%; height: 550px;
            background: var(--c2);
            border-radius: 300px 50px 300px 50px; /* AI Organic Shape */
            overflow: hidden;
            transform: rotate(-2deg);
            border: 10px solid white;
            box-shadow: 30px 30px 0 var(--c4);
        }

        .hero-image-frame img {
            width: 100%; height: 100%; object-fit: cover;
            animation: subtleZoom 10s infinite alternate;
        }

        @keyframes subtleZoom { from { transform: scale(1); } to { transform: scale(1.1); } }

        /* 4. RESEARCH SECTION - HORIZONTAL SCROLL LOOK */
        #research { background: rgba(255,255,255,0.2); }
        .research-card {
            background: white; border-radius: 50px 0 50px 0;
            padding: 60px; margin-bottom: 30px;
            display: flex; justify-content: space-between; align-items: flex-end;
            border-left: 15px solid var(--c3);
            transition: 0.5s;
        }
        .research-card:hover { transform: scale(1.02); background: var(--c4); }

        /* 5. TEACHING SECTION - BUBBLE MATRIX */
        .teaching-container {
            display: flex; flex-wrap: wrap; gap: 30px; justify-content: center;
        }
        .bubble {
            width: 280px; height: 280px; background: var(--c2); color: var(--c1);
            border-radius: 50%; display: flex; flex-direction: column;
            justify-content: center; align-items: center; text-align: center;
            padding: 30px; transition: 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .bubble:nth-child(even) { background: var(--c3); margin-top: 50px; }
        .bubble:hover { transform: scale(1.1) rotate(10deg); }

        /* 6. PORTFOLIO - MASONRY STYLE */
        .portfolio-masonry {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px;
        }
        .port-box {
            background: var(--c4); height: 300px; border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Syncopate'; font-size: 0.8rem; border: 1px solid var(--c2);
            position: relative; overflow: hidden;
        }
        .port-box.tall { grid-row: span 2; height: 615px; background: var(--c2); color: white; }
        .port-box:after {
            content: "VIEW_PROJECT"; position: absolute; bottom: -50px;
            transition: 0.3s; font-size: 0.6rem; letter-spacing: 3px;
        }
        .port-box:hover:after { bottom: 20px; }

        /* 7. CONTACT - MINIMAL GLITCH */
        .contact-box {
            background: var(--c2); color: var(--c1); padding: 80px;
            border-radius: 0 150px 0 150px; text-align: center;
        }
        .ai-btn {
            padding: 20px 60px; background: var(--c3); border: none;
            color: var(--c2); font-family: 'Syncopate'; cursor: pointer;
            font-weight: 700; transition: 0.3s; margin-top: 30px;
        }
        .ai-btn:hover { letter-spacing: 10px; background: var(--c4); }

        footer { padding: 60px; text-align: center; font-size: 0.7rem; letter-spacing: 8px; opacity: 0.6; }

        /* RESPONSIVE */
        @media (max-width: 900px) {
            .hero-grid { grid-template-columns: 1fr; text-align: center; }
            .hero-image-frame { height: 350px; border-radius: 100px; }
            .portfolio-masonry { grid-template-columns: 1fr; }
            .research-card { flex-direction: column; align-items: flex-start; gap: 20px; }
        }
    </style>
</head>
